{
  "name": "my-chat",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "nuxi dev",
    "build": "nuxi build",
    "generate": "nuxi generate",
    "preview": "nuxi preview",
    "postinstall": "nuxi prepare",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:unit": "vitest run tests/unit",
    "test:component": "vitest run tests/component",
    "test:api": "vitest run tests/api",
    "test:e2e": "playwright test --grep-invert \"真实 LLM 冒烟测试\"",
    "test:e2e:ui": "playwright test --ui",
    "test:smoke": "playwright test tests/e2e/llm-smoke.spec.ts --project=chromium",
    "test:all": "npm run test:unit && npm run test:component && npm run test:api && npm run test:e2e",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:generate": "drizzle-kit generate",
    "lint": "npm-run-all -p lint:js lint:css",
    "lint:js": "eslint . --max-warnings 0",
    "lint:js:fix": "eslint . --fix --max-warnings 0",
    "lint:css": "stylelint \"**/*.{css,vue}\"",
    "lint:css:fix": "stylelint \"**/*.{css,vue}\" --fix",
    "lint:fix": "npm-run-all -p lint:js:fix lint:css:fix",
    "format": "prettier --write .",
    "typecheck": "nuxt typecheck"
  },
  "dependencies": {
    "@ai-sdk/mcp": "^1.0.45",
    "@ai-sdk/openai": "^2.0.106",
    "@ai-sdk/vue": "^2.0.195",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@tanstack/vue-virtual": "^3.13.24",
    "ai": "^5.0.196",
    "drizzle-orm": "^0.36.0",
    "nuxt": "^3.15.0",
    "postgres": "^3.4.5",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@nuxtjs/tailwindcss": "^6.12.0",
    "@pinia/nuxt": "^0.11.3",
    "@playwright/test": "^1.49.0",
    "@types/node": "^25.6.0",
    "@typescript-eslint/parser": "^8.58.2",
    "@vitejs/plugin-vue": "^5.2.0",
    "@vue/test-utils": "^2.4.6",
    "c8": "^10.1.0",
    "dompurify": "^3.2.0",
    "drizzle-kit": "^0.29.0",
    "eslint": "^9.17.0",
    "eslint-plugin-vue": "^10.8.0",
    "highlight.js": "^11.11.0",
    "jsdom": "^25.0.0",
    "katex": "^0.16.11",
    "marked": "^15.0.0",
    "mermaid": "^11.14.0",
    "npm-run-all2": "^9.0.2",
    "pinia": "^3.0.4",
    "playwright": "^1.49.0",
    "prettier": "^3.4.0",
    "stylelint": "^17.14.0",
    "stylelint-config-recess-order": "^7.7.0",
    "stylelint-config-recommended-vue": "^1.6.1",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-config-tailwindcss": "^1.0.1",
    "tailwindcss": "^3.4.0",
    "tsx": "^4.22.4",
    "typescript": "^5.7.0",
    "unplugin-auto-import": "^21.0.0",
    "vitest": "^3.0.0",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^3.2.7"
  }
}

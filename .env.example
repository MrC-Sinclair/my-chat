# ============================================
# ⚠️ 重要说明：.env vs .env.example 区别
# ============================================
#
# 【.env.example】本文件 - 配置模板（已提交到 Git）
#   ✓ 用途：供团队参考配置格式
#   ✓ 内容：包含示例值或占位符
#   ✓ 状态：可安全提交到代码仓库
#
# 【.env】实际运行配置 - 本地私有文件（不提交 Git）
#   ✓ 用途：程序运行时读取的真实配置
#   ✓ 内容：包含真实的 API Key、密码等敏感信息
#   ✓ 状态：已在 .gitignore 中排除，不会泄露密钥
#
# 注意事项：
#   ⚠️ 本文件包含敏感信息，请勿提交到代码仓库！
#   ⚠️ 如需分享配置，请复制为 .env.example 后删除密钥
#
# ============================================

# --- 应用配置 ---
# 应用标题（显示在页面标题栏）
APP_TITLE=My Chat

# 系统提示词（决定 AI 的角色和行为规范，留空则使用内置默认提示词）
SYSTEM_PROMPT=你是一个友好的AI助手。请用简洁清晰的方式回答问题。当回答涉及可视化内容时（如示意图、图表、生物结构、地理信息等），请尽量使用 Markdown 图片语法 ![描述](URL) 插入相关图片来辅助说明。你可以引用 Wikipedia、Wikimedia Commons 等公开图片 URL。如果无法提供图片 URL，则仅用文字说明。【重要规则】当用户问题涉及以下内容时，你【必须】调用网页搜索工具，禁止凭记忆回答：- 任何包含"最新"、"今天"、"近期"、"当前"、"现在"、"最近"等时间词的问题

# --- LLM Provider 配置 ---
# 方案A: 硅基流动 SiliconFlow (推荐，免费，国内直连)
OPENAI_API_KEY=you-key
OPENAI_BASE_URL=https://api.siliconflow.cn/v1

#   默认选择          - 主模型 综合能力强 (默认)
LLM_MODEL=Qwen/Qwen3-8B

# 深度思考模式 (true=开启深度推理，更准但较慢；false=快速响应)
ENABLE_THINKING=true

# --- 图床配置 (图片对话必须) ---
# 免费注册: https://api.imgbb.com/ 获取 API Key
IMGBB_API_KEY=your-api-key

# --- 联网搜索配置 ---
# Tavily Search API (免费 1000 次/月)
# 注册: https://app.tavily.com
TAVILY_API_KEY=your-tavily-api-key

# --- PostgreSQL 数据库连接 ---
DATABASE_URL=postgresql://sw_pad:sw_pad_2026@localhost:5434/sw_pad

# 测试数据库连接
DATABASE_TEST_URL=postgresql://sw_pad_test:sw_pad_test@localhost:5433/sw_pad_test

# --- 长期记忆系统（可选，有默认值）---
# Embedding 模型：BAAI/bge-m3 输出 1024 维向量（与 schema.ts vector dimensions 对齐）
EMBEDDING_MODEL=BAAI/bge-m3
# 重排序模型：BAAI/bge-reranker-v2-m3，对 query-document 对做交叉编码精排
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
# 重要度判断模型：默认 Qwen/Qwen3.5-4B（轻量、toggleableThinking），用于会话归档时判断消息重要度
MEMORY_IMPORTANCE_MODEL=Qwen/Qwen3.5-4B

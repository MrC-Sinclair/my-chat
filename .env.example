# ============================================
# ⚠️ 重要说明：.env vs .env.example 区别
# ============================================
#
# 【.env.example】本文件 - 配置模板（已提交到 Git）
#   ✓ 用途：供团队参考配置格式
#   ✓ 内容：包含示例值或占位符
#   ✓ 状态：可安全提交到代码仓库
#
# 【.env】实际运行配置 - 本地私有文件（不提交 Git）
#   ✓ 用途：程序运行时读取的真实配置
#   ✓ 内容：包含真实的 API Key、密码等敏感信息
#   ✓ 状态：已在 .gitignore 中排除，不会泄露密钥
#
# 使用方法：
#   1. 复制本文件为 .env:  copy .env.example .env
#   2. 根据需要修改 .env 中的值
#   3. 运行程序时会自动读取 .env 文件
#
# ============================================

# --- 应用配置 ---
# 应用标题（显示在页面标题栏）
APP_TITLE=My Chat

# 系统提示词（决定 AI 的角色和行为规范，留空则使用内置默认提示词）
SYSTEM_PROMPT=你是一个友好的AI助手。请用简洁清晰的方式回答问题。

# --- LLM Provider 配置 ---
# 方案A: 硅基流动 SiliconFlow (推荐，免费，国内直连)
OPENAI_API_KEY=sk-your-api-key
OPENAI_BASE_URL=https://api.siliconflow.cn/v1

# 模型名称 (可自由切换)
# 常用免费模型:
#   Qwen/Qwen3-32B          - 综合能力强 (默认)
#   deepseek-ai/DeepSeek-V3 - 代码/推理强
#   THUDM/glm-4-9b-chat     - 轻量快速
LLM_MODEL=Qwen/Qwen3-8B

# 深度思考模式 (true=开启深度推理，更准但较慢；false=快速响应)
ENABLE_THINKING=true

# 方案B: OpenAI (付费)
# OPENAI_API_KEY=sk-your-openai-key
# OPENAI_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o

# 方案C: Google Gemini (免费，需代理)
# GOOGLE_GENERATIVE_AI_API_KEY=your-gemini-key

# --- PostgreSQL 数据库连接 ---
DATABASE_URL=postgresql://sw_pad:sw_pad_2026@localhost:5434/sw_pad

# 测试数据库连接
DATABASE_TEST_URL=postgresql://sw_pad_test:sw_pad_test@localhost:5433/sw_pad_test
